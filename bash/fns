  else
    command git "$@"
  fi
}

# -- ai ---------------------------------------------------------
ask() {
  local user_prompt="$*"
  local system_prompt='Respond concisely and in plain text only, no markdown formatting or special characters'

  local model='google/gemini-2.0-flash-exp:free'
  local model='deepseek/deepseek-chat-v3-0324:free'
  local model='meta-llama/llama-4-scout:free'

  local model_to_use="$model"
  local result=$(curl -s https://openrouter.ai/api/v1/chat/completions \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $OPENROUTER_API_KEY" \
    -d '{
      "model": "'"${model_to_use}"'",
      "messages": [
        {
          "role": "system",
          "content": [
            {
              "type": "text",
              "text": "'"${system_prompt//\"/\\\"}"'"
            }
          ]
        },
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "'"${user_prompt//\"/\\\"}"'"
            }
          ]
        }
      ]
    }')
  local answer="$(echo $result | jq -r '.choices[0].message.content')"
  # echo "$result"
  echo "$answer"
}

