assume-role(){
  local acct="$1"
  local role_name="$2"
  local duration=${3:-3600}

  aws-mfa --duration "$duration" --profile "$acct" --assume-role "$("${EISH_HOME}/si-role-arn" -n "$acct" -r "$role_name")"
}

