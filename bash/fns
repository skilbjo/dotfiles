set -u

# -- general ----------------------------------------------------
kmsd(){
  # https://stackoverflow.com/a/53735748/2490091
  # call it like: `pbpaste | kmsd`
  aws kms decrypt \
    --profile personal \
    --ciphertext-blob fileb://<( \
      cat /dev/stdin | \
      sed 's/.*kmscrypt:://' | \
      tr -d '\n' | \
      base64 -D
    ) \
    --output text \
    --key-id "$aws_kms_key" \
    --region us-east-1 \
    --query Plaintext | \
  base64 -D
}

kmse(){
  # https://stackoverflow.com/a/53735748/2490091
  # call it like: `pbpaste | kmse`
  aws kms encrypt \
    --profile personal \
    --key-id "$aws_kms_key" \
    --plaintext "$(cat /dev/stdin)" \
    --region us-east-1 \
    --query CiphertextBlob \
    --output text
}

git() {
  if [[ $@ == 'push -f'* ]] || [[ $@ == 'pu -f'* ]]; then
